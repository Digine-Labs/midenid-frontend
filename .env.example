# Miden Contract Addresses
# Used in: src/shared/constants.ts, src/providers/MidenClientProvider.tsx,
#          src/components/RegisterModal.tsx, src/components/register-modal/RegistrationStep.tsx
VITE_MIDEN_ID_CONTRACT_ADDRESS=0x88f63686037e63406bbb8f5d01adb0
VITE_MIDEN_FAUCET_CONTRACT_ADDRESS=0x0a7d175ed63ec5200fb2ced86f6aa5
VITE_MIDEN_FAUCET_ID_BECH32=mtst1aq9869676clv2gq0kt8dsmm255zs6hs3_qr7qqq9wr6w

# API Configuration
# Used in: src/api/profile.ts, src/api/accounts.ts
# Domain-availability checks no longer hit the backend (commit 1d4098d "no bakcend"
# moved them on-chain via MidenClientProvider.getDomainOwner). The backend is still
# called for profile CRUD, profile-picture upload, and account->domains lookup.
VITE_API_BASE=https://midenid-backend.onrender.com

# File Upload Configuration (in bytes) — 5 * 1024 * 1024 = 5 MB
# Used in: src/shared/constants.ts -> src/pages/identity/components/IdentityProfile.tsx
VITE_MAX_FILE_SIZE=5242880
